# Server Configuration
PORT=3000
NODE_ENV=development
APP_NAME=Artisans Hub API
APP_URL=http://localhost:3000

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=artisans_hub
DB_USER=postgres
DB_PASSWORD=your_secure_password
DB_POOL_MIN=2
DB_POOL_MAX=10

# JWT Configuration
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRE=7d
JWT_REFRESH_SECRET=your_refresh_secret_key
JWT_REFRESH_EXPIRE=30d

# Mobile Money (Momo) Configuration
MOMO_API_KEY=your_momo_api_key
MOMO_API_SECRET=your_momo_api_secret
MOMO_BASE_URL=https://api.momoapi.example.com
MOMO_PRIMARY_KEY=your_momo_primary_key
MOMO_SUBSCRIPTION_KEY=your_momo_subscription_key

# Admin Configuration
ADMIN_EMAIL=admin@artisanshub.gh
ADMIN_PHONE=+233XXXXXXXXXX
ADMIN_MOMO_NUMBER=+233XXXXXXXXXX

# Frontend URLs
FRONTEND_MOBILE_URL=http://localhost:19000
FRONTEND_WEB_URL=http://localhost:3000
FRONTEND_ADMIN_URL=http://localhost:3001

# Commission & Fees
PLATFORM_COMMISSION=0.15
MINIMUM_WITHDRAWAL=50
MAXIMUM_WITHDRAWAL=5000

# Email Configuration
EMAIL_SERVICE=gmail
EMAIL_USER=your_email@gmail.com
EMAIL_PASSWORD=your_app_password
EMAIL_FROM=noreply@artisanshub.gh

# Logging
LOG_LEVEL=info
LOG_FILE=logs/app.log

# Security
BCRYPT_ROUNDS=10
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# File Upload
MAX_FILE_SIZE=5242880
ALLOWED_IMAGE_TYPES=image/jpeg,image/png,image/gif
UPLOAD_DIR=./uploads

# Twilio (Optional - for SMS)
TWILIO_ACCOUNT_SID=your_twilio_sid
TWILIO_AUTH_TOKEN=your_twilio_token
TWILIO_PHONE_NUMBER=+1234567890

# Redis (Optional - for caching)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# AWS S3 (Optional - for file storage)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_aws_key
AWS_SECRET_ACCESS_KEY=your_aws_secret
AWS_S3_BUCKET=artisans-hub-uploads
